# ============================================================
# AI Research Agent — Environment Configuration Template
# Copy this file to .env and fill in your own values.
# ============================================================

# ----------------------------------------------------------
# Required: OpenAI API key for GPT-4 summarization
# ----------------------------------------------------------
OPENAI_API_KEY=sk-...

# OpenAI model to use (default: gpt-4o)
# Options: gpt-4, gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# ----------------------------------------------------------
# Optional: Semantic Scholar API key (higher rate limits)
# Get one at: https://www.semanticscholar.org/product/api
# ----------------------------------------------------------
SEMANTIC_SCHOLAR_API_KEY=

# ----------------------------------------------------------
# Optional: Email for Unpaywall API (open-access PDF lookup)
# ----------------------------------------------------------
UNPAYWALL_EMAIL=your_email@example.com

# ----------------------------------------------------------
# Local storage paths
# ----------------------------------------------------------
PAPERS_DIR=papers
OUTPUT_DIR=output

# ----------------------------------------------------------
# Search defaults
# ----------------------------------------------------------
DEFAULT_MAX_RESULTS=20

# ----------------------------------------------------------
# PDF download settings
# ----------------------------------------------------------
DOWNLOAD_TIMEOUT=30
DOWNLOAD_RETRIES=3
DOWNLOAD_BACKOFF=2.0

# ----------------------------------------------------------
# LLM token limits
# ----------------------------------------------------------
SUMMARIZE_MAX_TOKENS=1500
ANALYSIS_MAX_TOKENS=2000
IDEAS_MAX_TOKENS=2500
PDF_TEXT_LIMIT=12000

# ----------------------------------------------------------
# Logging
# ----------------------------------------------------------
LOG_LEVEL=INFO
# LOG_FILE=research_agent.log
